# Groq API keys. Multiple keys are rotated round-robin to stay
# under the 25 req/min rate limit per key.
# Provide as a comma-separated list (no spaces required, they will be stripped).
GROQ_API_KEYS=gsk_your_first_key_here,gsk_your_second_key_here

# Model to use for all LLM calls.
GROQ_MODEL=llama-3.3-70b-versatile

# Per-key rate limit safety margin (requests per minute).
GROQ_RPM_PER_KEY=25

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
